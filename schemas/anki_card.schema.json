{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/anki_card.schema.json",
  "title": "Anki Card",
  "description": "Schema for cards generated by the anki-cardmaker skill.",
  "oneOf": [
    {
      "type": "object",
      "required": ["type", "front", "back"],
      "additionalProperties": true,
      "properties": {
        "schema_version": {
          "type": "string",
          "default": "1.0"
        },
        "question_type": {
          "type": "string",
          "enum": ["vocabulary_meaning", "cloze", "single_choice", "multiple_choice", "true_false", "short_answer", "词义题", "填空题", "单选题", "多选题", "判断题", "简答题"]
        },
        "type": {
          "type": "string",
          "enum": ["QA", "Basic", "qa", "basic"]
        },
        "front": {
          "type": "string",
          "minLength": 1
        },
        "back": {
          "type": "string",
          "minLength": 1
        },
        "back_zh": {
          "type": "string",
          "description": "Chinese translation for the answer/back text."
        },
        "explanation": {
          "type": "string"
        },
        "explanation_zh": {
          "type": "string",
          "description": "Chinese translation or explanation for the card."
        },
        "mnemonic_hook": {
          "type": "string"
        },
        "mnemonic_hook_zh": {
          "type": "string",
          "description": "Chinese translation for the mnemonic hook."
        },
        "core_keywords": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          ],
          "description": "Automatically extracted or manually supplied core keywords."
        },
        "synonyms": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          ],
          "description": "Optional synonym hints."
        },
        "antonyms": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          ],
          "description": "Optional antonym hints."
        },
        "contrast_terms": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          ],
          "description": "Optional contrasting terms surfaced automatically or manually."
        },
        "example_sentence": {
          "type": "string",
          "description": "Optional or automatically generated example sentence."
        },
        "example_sentence_zh": {
          "type": "string",
          "description": "Chinese translation for the example sentence."
        },
        "mnemonic_image_path": {
          "type": "string",
          "description": "Absolute path to a local image file."
        },
        "tags": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          ]
        },
        "source": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "title": { "type": "string" },
            "url": { "type": "string" },
            "file": { "type": "string" },
            "page": { "type": ["integer", "string"] },
            "chapter": { "type": "string" }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["type", "front", "correct_answer", "options"],
