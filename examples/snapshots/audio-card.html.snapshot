# Stable HTML contract for one-click pronunciation controls.
<button type="button" class="anki-audio-button" aria-label="播放读音" onclick="event.stopPropagation();var a=this.nextElementSibling;a.currentTime=0;a.play();return false;">▶</button>
<audio class="anki-audio-control" preload="none" src="anki_word_defy.mp3"></audio>
